# ─── App Config ───
NODE_ENV=production
PORT=3000

# ─── Database ───
# ⚠️ เปลี่ยนจาก localhost เป็น 'mysql' (ชื่อ service ใน docker-compose.yml)
DB_HOST=mysql 
DB_PORT=3306
# เปลี่ยน DB_USER ให้ตรงกับที่ตั้งไว้ใน docker-compose (เช่น 'admin')
DB_USERNAME=admin 
DB_PASSWORD=password123
DB_NAME=cinema_booking

# ─── JWT & Others ───
JWT_SECRET=your-super-secret-jwt-key-min-32-char
JWT_EXPIRES_IN=7d
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
CORS_ORIGIN=http://localhost:4200